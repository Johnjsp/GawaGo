Table auth_user {
  id int [pk]
  password varchar(128) [not null]
  last_login datetime
  is_superuser boolean [not null]
  username varchar(150) [not null, unique]
  first_name varchar(150) [not null]
  last_name varchar(150) [not null]
  email varchar(254) [not null]
  is_staff boolean [not null]
  is_active boolean [not null]
  date_joined datetime [not null]
}

Table accounts_userprofile {
  id bigint [pk]
  user_id int [not null, unique, ref: > auth_user.id]
  role varchar(20) [not null]
  phone varchar(30) [not null]
  bio text [not null]
  years_experience int [not null]
  skills json [not null]
  hourly_rate decimal(10,2)
  daily_rate decimal(10,2)
  verification_status varchar(20) [not null]
  location_label varchar(255) [not null]
  latitude decimal(10,7)
  longitude decimal(10,7)
  profile_photo varchar(100)
  average_rating decimal(3,2)
  rating_count int [not null]
}

Table accounts_workeravailability {
  id bigint [pk]
  worker_id int [not null, ref: > auth_user.id]
  date date [not null]
  start_time time [not null]
  end_time time [not null]
  is_available boolean [not null]

  indexes {
    (worker_id, date, start_time, end_time) [unique]
  }
}

Table accounts_passwordresetrequest {
  id bigint [pk]
  user_id int [not null, ref: > auth_user.id]
  email varchar(254) [not null]
  token_hash varchar(128) [not null]
  created_at datetime [not null]
  expires_at datetime [not null]
  used_at datetime
  attempts int [not null]

  indexes {
    (email, created_at)
  }
}

Table accounts_signupverificationrequest {
  id bigint [pk]
  user_id int [not null, unique, ref: > auth_user.id]
  email varchar(254) [not null]
  token_hash varchar(128) [not null]
  created_at datetime [not null]
  expires_at datetime [not null]
  verified_at datetime
}

Table jobs_jobposting {
  id bigint [pk]
  household_id int [not null, ref: > auth_user.id]
  title varchar(255) [not null]
  job_type varchar(120) [not null]
  required_skill varchar(120) [not null]
  schedule varchar(255) [not null]
  schedule_type varchar(80) [not null]
  preferred_date date
  preferred_time time
  description text [not null]
  location_label varchar(255) [not null]
  latitude decimal(10,7) [not null]
  longitude decimal(10,7) [not null]
  service_rate decimal(10,2) [not null]
  worker_slots int [not null]
  status varchar(20) [not null]
  created_at datetime [not null]
  completed_at datetime
}

Table jobs_jobapplication {
  id bigint [pk]
  job_id bigint [not null, ref: > jobs_jobposting.id]
  worker_id int [not null, ref: > auth_user.id]
  status varchar(20) [not null]
  applied_at datetime [not null]
  updated_at datetime [not null]
  note text [not null]

  indexes {
    (job_id, worker_id) [unique]
  }
}

Table jobs_jobimage {
  id bigint [pk]
  job_id bigint [not null, ref: > jobs_jobposting.id]
  image varchar(100) [not null]
  uploaded_at datetime [not null]
  order int [not null]
}

Table reviews_review {
  id bigint [pk]
  author_id int [not null, ref: > auth_user.id]
  target_id int [not null, ref: > auth_user.id]
  author_role varchar(20) [not null]
  target_role varchar(20) [not null]
  job_id bigint [ref: > jobs_jobposting.id]
  job_title varchar(255) [not null]
  rating decimal(2,1)
  feedback text [not null]
  created_at datetime [not null]
}

Table notifications_notification {
  id bigint [pk]
  recipient_id int [not null, ref: > auth_user.id]
  notification_type varchar(30) [not null]
  title varchar(255) [not null]
  message text [not null]
  is_read boolean [not null]
  created_at datetime [not null]
}

Table common_verificationrequest {
  id bigint [pk]
  worker_id int [not null, ref: > auth_user.id]
  primary_id_name varchar(255) [not null]
  secondary_doc_name varchar(255) [not null]
  primary_id_file varchar(100)
  secondary_doc_file varchar(100)
  notes text [not null]
  status varchar(20) [not null]
  submitted_at datetime [not null]
  reviewed_at datetime
  review_note text [not null]
}
